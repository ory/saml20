{
  "compilerOptions": {
    "rootDir": "./lib",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2019",
    "lib": ["ES2019"],

    "declaration": true,
    "sourceMap": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "noUnusedParameters": true,

    "experimentalDecorators": true,
    "noImplicitAny": false,
  },
  "include": ["./lib/**/*"],
  "exclude": ["node_modules", "test/**/*"],
}
